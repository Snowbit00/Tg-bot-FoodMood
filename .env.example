# Скопируйте этот файл в .env и впишите свои значения.
# .env НЕ коммитится (см. .gitignore).

# ── Текст рецептов: DeepSeek (прямой API) ──
DEEPSEEK_API_KEY=

# ── Картинки: YandexART (Yandex AI Studio) ──
# Для YandexART сервисному аккаунту нужна роль ai.imageGenerationModels.user.
# (Эти же ключ+folder можно использовать и для текста — см. text_api в config.yaml.)
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# ── Telegram ──
# Токен бота от @BotFather. Бот должен быть АДМИНИСТРАТОРОМ канала.
TELEGRAM_BOT_TOKEN=123456:ABC-...
# ID канала: @username публичного канала ИЛИ числовой -100xxxxxxxxxx
TELEGRAM_CHANNEL_ID=@my_recipes_channel
# Кто может управлять ботом через команды (/post и т.д.) — ваш Telegram user id.
# Несколько — через запятую. Узнать свой ID: напишите боту /start или @userinfobot.
TELEGRAM_ADMIN_IDS=
